generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id              String        @id @default(uuid())
  nom             String
  prenom          String
  email           String
  cin             String
  idAsebem        String
  pack            String
  nombrePersonnes Int
  createdAt       DateTime      @default(now())
  beneficiaires   Beneficiary[]
}

model Beneficiary {
  id        String @id @default(uuid())
  nom       String
  prenom    String
  cin       String
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
